<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/black">

    <!-- Header with title and default/reset buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filter"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/textColor" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/set_default_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Set Default"
                android:textSize="11sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                style="@style/BlackButton" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nsfw_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show NSFW"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/nsfw_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/genres_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genres"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/genres_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/genres_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/genres_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:id="@+id/tags_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tags"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/tags_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/tags_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tags_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:id="@+id/year_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Year"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/year_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/year_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/year_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:id="@+id/season_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Season"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/season_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/season_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/season_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:id="@+id/format_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Format"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/format_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/format_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/format_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:id="@+id/sort_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@android:color/black">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textColor" />

            <TextView
                android:id="@+id/sort_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Popularity"
                android:textSize="12sp"
                android:textColor="?attr/grayTextColor" />

        </LinearLayout>

        <ImageView
            android:id="@+id/sort_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_baseline_arrow_forward_24"
            android:tint="?attr/textColor"
            android:contentDescription="Expand" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sort_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:nestedScrollingEnabled="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clear_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Clear"
            style="@style/BlackButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply"
            style="@style/WhiteButton" />

    </LinearLayout>

</LinearLayout>
