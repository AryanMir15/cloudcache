<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Exclude state (red filled with X) - triggered by custom state -->
    <item android:state_checked="true">
        <layer-list xmlns:android="http://schemas.android.com/apk/res/android">
            <!-- Red filled box -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#FF5252" />
                    <corners android:radius="2dp" />
                    <size android:width="18dp" android:height="18dp" />
                </shape>
            </item>
            <!-- White X -->
            <item android:gravity="center">
                <vector android:height="24dp" android:viewportHeight="24" android:viewportWidth="24" android:width="24dp">
                    <path android:fillColor="@android:color/white" android:pathData="M19,6.41L17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12z"/>
                </vector>
            </item>
        </layer-list>
    </item>
    <!-- Default checkbox state -->
    <item android:drawable="?android:attr/listChoiceIndicatorMultiple" />
</selector>
